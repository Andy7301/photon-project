# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Routing: who can trigger Drafts
# allowlist — only senders in ALLOWED_SENDERS (recommended)
# prefix — message must start with DRAFTS_PREFIX
# any_dm — every direct message (dev only)
DRAFTS_MODE=allowlist

# Comma-separated phone numbers or emails as shown in iMessage sender field
ALLOWED_SENDERS=+15551234567

# Used when DRAFTS_MODE=prefix
DRAFTS_PREFIX=Drafts:

# Optional: JSON file for memory + reminder metadata
MEMORY_PATH=./data/memory.json

DEBUG=false
